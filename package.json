{
  "name": "@mudbean/is",
  "type": "module",
  "private": true,
  "version": "2.0.4",
  "scripts": {
    "b": "rollup --config rollup.config.js && tsc -p tsconfig.types.json",
    "clean:package": "node scripts/clean-package-json.js",
    "build": "jja rm dist cls && pnpm run b && pnpm run clean:package",
    "build:local": "jja rm dist cls && node scripts/build-local.js",
    "diff": "jja pkg --diff",
    "push:version": "gvv",
    "push": "gvv",
    "eslint": "jja cls && eslint src",
    "beautify": "pnpm run prettier",
    "prettier": "jja cls && prettier . --write",
    "vjj": "vjj",
    "prepublishOnly": "pjj"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@qqi/check-version": "^1.1.0",
    "@qqi/copy-text": "^1.1.0",
    "@qqi/rollup-external": "^1.1.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "a-node-tools": "^4.4.2",
    "color-pen": "^3.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsdoc": "^62.8.0",
    "globals": "^17.4.0",
    "gvv": "^1.0.0",
    "jja": "^2.4.0",
    "pjj": "^1.0.5",
    "prettier": "^3.8.1",
    "rollup": "^4.60.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vjj": "^1.0.12"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}